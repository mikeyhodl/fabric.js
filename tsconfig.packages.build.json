{
  "extends": "./tsconfig.packages.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    // Workspace packages publish only `dist` (no `src`), so declaration maps
    // would point at sources that are never shipped. Keep them off.
    "declarationMap": false,
    "rootDir": ".",
    "outDir": "./cli_output/package-types"
  }
}
