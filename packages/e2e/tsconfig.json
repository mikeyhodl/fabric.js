{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "strict": true,
    "sourceMap": true,
    "outDir": "./dist",
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "allowSyntheticDefaultImports": true,
    /**
     * A reflection of the configured imports used by test scripts.
     * Runtime-facing imports that Playwright executes in Node should point at
     * fully bundled root outputs to avoid re-entering workspace source during
     * Playwright's own TS/Babel transform step.
     */
    "paths": {
      "@fabricjs/aligning-guidelines": ["../aligning-guidelines/dist/index"],
      "@fabricjs/browser": ["../browser/dist/index"],
      "@fabricjs/core": ["../../dist/packages/core/src/index"],
      "@fabricjs/cropping-controls": ["../cropping-controls/dist/index"],
      "@fabricjs/data-updaters": ["../data-updaters/dist/index"],
      "@fabricjs/gradient-controls": ["../gradient-controls/dist/index"],
      "@fabricjs/node": ["../../dist/index.node"],
      "@fabricjs/westures-integration": ["../westures-integration/dist/index"],
      "fabric": ["../../dist/index"],
      "fabric/extensions": ["../../dist-extensions/extensions/index"],
      "fabric/node": ["../../dist/index.node"]
    },
    "resolveJsonModule": true
  },
  "include": ["./**/*.ts", "env.d.ts"],
  "exclude": []
}
